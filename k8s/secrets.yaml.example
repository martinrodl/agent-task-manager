# Copy to secrets.yaml, fill in real values (base64-encoded), then:
#   kubectl apply -f k8s/secrets.yaml
#
# To base64-encode a value:  echo -n "myvalue" | base64
#
# NEVER commit secrets.yaml to git — it's in .gitignore

apiVersion: v1
kind: Secret
metadata:
  name: agenttask-secrets
  namespace: agent-task-manager
type: Opaque
data:
  # echo -n "postgresql://agenttask:CHANGE_ME@agent-task-db:5432/agenttask" | base64
  DATABASE_URL: cG9zdGdyZXNxbDovL2FnZW50dGFzazpDSEFOR0VfTUVAYWdlbnQtdGFzay1kYjo1NDMyL2FnZW50dGFzaw==

  # echo -n "$(openssl rand -hex 32)" | base64
  SECRET_KEY: Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24=

  # echo -n "your-admin-password" | base64
  ADMIN_PASSWORD: YWRtaW4=

  # echo -n "$(openssl rand -hex 24)" | base64
  AGENT_API_KEY: YWdlbnQta2V5LWNoYW5nZS1tZQ==

  # echo -n "$(openssl rand -hex 24)" | base64
  ORCHESTRATOR_API_KEY: b3JjaGVzdHJhdG9yLWtleS1jaGFuZ2UtbWU=
