# Database
DATABASE_URL="postgresql://agenttask:secret@localhost:5432/agenttask"

# Auth — change all of these before deploying
SECRET_KEY="change-me-to-a-random-32-char-string"
ADMIN_PASSWORD="admin"

# API keys for agents (use long random strings in production)
# Agents call the API with:  Authorization: Bearer <key>  +  X-Agent-Id: my-agent-name
AGENT_API_KEY="agent-key-change-me"
ORCHESTRATOR_API_KEY="orchestrator-key-change-me"

# ─── Claude Code / MCP Server setup ──────────────────────────────────────────
# After starting AgentTask, register the MCP server with Claude Code:
#
#   cd apps/agenttask/mcp-server
#   npm install
#   claude mcp add agenttask \
#     -e AGENTTASK_URL=http://localhost:3000 \
#     -e AGENTTASK_API_KEY=agent-key-change-me \
#     -e AGENTTASK_AGENT_ID=claude-code \
#     -- npx tsx /absolute/path/to/mcp-server/index.ts
#
# Then in any Claude Code session: use list_tasks / get_task / transition_task tools
# to read and process tasks directly from the CLI.
#
# For automated (no-human) processing: create an Agent in the UI with:
#   Provider: "Claude Code (local CLI)"
#   Path to claude binary: leave blank (uses PATH) or e.g. /usr/local/bin/claude
#   Model: claude-opus-4-6  (or leave as "default")
# Then assign that agent to workflow states in the Workflow Builder.
